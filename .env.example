# ─── ARKI Desktop — Environment Configuration ───────────────────────────────
# Copy to .env and fill in your values. NEVER commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                    # development | production
APP_NAME=ARKI
APP_VERSION=1.0.0
LOG_LEVEL=info                         # debug | info | warning | error
SECRET_KEY=change-me-to-random-32-char-string

# ── Backend Server ─────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
WEBSOCKET_PORT=8765
CORS_ORIGINS=["http://localhost:5173"]  # Electron renderer origin

# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenAI (cloud — used for advanced reasoning and cloud OCR)
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini       # realtime triggers
OPENAI_ANALYSIS_MODEL=gpt-4o           # deep analysis (manual only)
OPENAI_MAX_TOKENS=300
OPENAI_TEMPERATURE=0.3

# Ollama (local — used for offline/privacy-first inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_ANALYSIS_MODEL=llama3.2:70b

# AI Provider Selection
AI_PROVIDER=openai                     # openai | ollama | auto (auto = ollama first, fallback openai)
AI_COST_ALERT_USD=0.30
AI_COST_MAX_USD=0.50

# ── OCR Providers ─────────────────────────────────────────────────────────────
# Tesseract (local — always available)
TESSERACT_CMD=/usr/local/bin/tesseract  # Path to tesseract binary
TESSERACT_LANG=eng+spa                 # Languages to detect
TESSERACT_PSM=3                        # Page segmentation mode (3=auto)
TESSERACT_OEM=3                        # OCR engine mode (3=default LSTM)

# OpenAI Vision OCR (cloud — higher accuracy for complex images)
OPENAI_VISION_ENABLED=false
OPENAI_VISION_MODEL=gpt-4o

# EasyOCR (local ML — best for multilingual)
EASYOCR_ENABLED=false
EASYOCR_LANGUAGES=["en","es"]
EASYOCR_GPU=false                      # Set true if CUDA available

# OCR Provider Selection
OCR_PROVIDER=tesseract                 # tesseract | easyocr | openai_vision | auto

# ── Screen Capture ─────────────────────────────────────────────────────────────
CAPTURE_LATENCY_TARGET_MS=150          # Target: <150ms
CAPTURE_FORMAT=png                     # png | jpg (png = lossless for OCR)
CAPTURE_QUALITY=95                     # jpg quality (ignored for png)

# ── Session & Memory ──────────────────────────────────────────────────────────
SESSION_DB_PATH=./data/sessions.db
VECTOR_DB_PATH=./data/chroma
MAX_SESSION_MEMORY_MB=256
CONTEXT_WINDOW_MINUTES=3
ROLLING_SUMMARY_INTERVAL_MINUTES=5
MAX_CONTEXT_TOKENS=1500

# ── Hotkeys (Electron GlobalShortcut) ─────────────────────────────────────────
HOTKEY_CAPTURE=CommandOrControl+Shift+S    # Trigger OCR capture
HOTKEY_TOGGLE_OVERLAY=CommandOrControl+Shift+A  # Show/hide overlay
HOTKEY_ANALYZE=CommandOrControl+Shift+X   # Deep AI analysis
HOTKEY_CLEAR=CommandOrControl+Shift+C     # Clear session

# ── Overlay Window ────────────────────────────────────────────────────────────
OVERLAY_OPACITY=0.92
OVERLAY_WIDTH=420
OVERLAY_HEIGHT=600
OVERLAY_POSITION=top-right             # top-right | top-left | bottom-right | bottom-left | center
OVERLAY_ALWAYS_ON_TOP=true
OVERLAY_CLICK_THROUGH=false            # true = overlay doesn't capture mouse clicks

# ── Security ──────────────────────────────────────────────────────────────────
ENABLE_CONTENT_SECURITY_POLICY=true
ENCRYPT_LOCAL_STORAGE=true
LOCAL_STORAGE_KEY=                     # Auto-generated if empty
