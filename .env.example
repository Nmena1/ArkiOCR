# ── Backend ────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── OCR ───────────────────────────────────────────────
OCR_PROVIDER=tesseract          # tesseract | easyocr | openai-vision
OCR_LANGUAGE=eng

# ── AI ────────────────────────────────────────────────
AI_PROVIDER=ollama              # ollama | openai | claude
AI_MODEL=llama3.2               # for ollama; or gpt-4o-mini for openai
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── API Keys (only needed for cloud providers) ─────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Dev ───────────────────────────────────────────────
NODE_ENV=development
