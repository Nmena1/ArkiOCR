{
  "name": "arki",
  "version": "2.0.0",
  "description": "ARKI — Headless AI Desktop Assistant",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsc -p electron/tsconfig.json --watch & sleep 2 && electron dist/electron/main.js",
    "build": "tsc -p electron/tsconfig.json",
    "start": "electron dist/electron/main.js",
    "typecheck": "tsc --noEmit -p electron/tsconfig.json",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.5",
    "concurrently": "^9.0.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.arki.desktop",
    "productName": "ARKI",
    "asar": true,
    "directories": { "output": "out" },
    "files": [
      "dist/**/*",
      "popup/**/*",
      "config/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "../backend", "to": "backend", "filter": ["**/*", "!**/__pycache__", "!**/*.pyc"] },
      { "from": "popup", "to": "popup" },
      { "from": "config", "to": "config" }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSScreenCaptureDescription": "ARKI needs screen recording permission to capture and analyze screen content.",
        "LSUIElement": true
      }
    },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
